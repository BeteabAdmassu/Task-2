# MeridianCare — Production Environment Variables
# ------------------------------------------------
# Copy this file to .env (or export the variables in your shell / systemd unit)
# before starting the app with FLASK_ENV=production.
#
# All three secret variables MUST be set. The app raises RuntimeError at
# startup if any are missing. Keep them stable across restarts:
#   - Changing ENCRYPTION_KEY makes all encrypted patient data unreadable.
#   - Changing SECRET_KEY invalidates every active browser session.
#
# NEVER commit real secret values to version control.

# Flask session signing key — 32+ bytes of random hex.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet symmetric key for field-level encryption (base64url, 32 bytes).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# HMAC-SHA256 signing secret for anti-replay request fields.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
REQUEST_SIGNING_SECRET=

# Flask environment — must be "production" for deployed instances.
FLASK_ENV=production

# Optional: override the default SQLite path (use an absolute path on a
# persistent volume so data survives container restarts).
# DATABASE_URL=sqlite:////data/meridiancare.db

# Optional: override the listening port (default: 5000).
# PORT=5000
